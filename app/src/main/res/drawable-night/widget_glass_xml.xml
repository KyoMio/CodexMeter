<?xml version="1.0" encoding="utf-8"?>
<!--
  DARK "liquid glass" widget backdrop, pure <layer-list>/<shape> reproduction.
  Mirrors the light variant structure with dark-glass values; auto-swapped by the
  launcher under -night. A/B spike artifact vs the runtime-bitmap renderer; DESIGN.md §912.
  Layers bottom->top: contact shadow, frosted body, internal refraction lens,
  top highlight, double hairline rim (outer cool stroke + inner white).
  Corner radius ~24dp; ~3dp inset so the contact shadow/rim read.
  Pure XML can do no Gaussian blur and no off-bounds clipping, so the refraction
  lens is kept fully internal (upper-left, not reaching the edges).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Contact shadow: deeper dark drop shadow, slight downward offset for a subtle float. Kept close
         to the body inset so it doesn't protrude as an uneven bottom edge. glassShadow #060810 @ ~0.4 -> #66060810 -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="4dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#66060810" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Frosted body: cool blue-gray dark glass, diagonal gradient. start rgba(36,48,66,0.55)->#8C243042, end rgba(22,30,43,0.6)->#99161E2B -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#8C243042"
                android:endColor="#99161E2B"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Internal refraction lens: faint cool-blue radial oval, lower alpha than light, fading to transparent. Kept internal. glassTintBlue #5DB8FF @ ~0.12 -> #1F5DB8FF -->
    <item
        android:left="14dp"
        android:right="46dp"
        android:top="12dp"
        android:bottom="44dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="55%"
                android:centerX="0.32"
                android:centerY="0.30"
                android:startColor="#1F5DB8FF"
                android:endColor="#005DB8FF" />
        </shape>
    </item>

    <!-- Top sheen: very low-alpha vertical white->transparent gradient over the FULL body shape so it
         nests inside the rounded corners (no overflow / hard edges) and scales with any widget height.
         Subtle so it never washes the dark glass content. -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#1FFFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Single hairline rim, cool stroke. (A second inset rim diverged from this one when the launcher
         stretches the drawable to non-square widget sizes, so the double rim is collapsed to one.)
         glassStrokeCool-aligned #3E5A7A @ ~0.30 -> #4D3E5A7A -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#4D3E5A7A" />
            <corners android:radius="24dp" />
        </shape>
    </item>

</layer-list>
