<?xml version="1.0" encoding="utf-8"?>
<!--
  DARK "liquid glass" widget backdrop, pure <layer-list>/<shape> reproduction.
  Mirrors the light variant structure with dark-glass values; auto-swapped by the
  launcher under -night. DESIGN.md §912.
  Layers bottom->top: contact shadow, frosted body, top sheen, single hairline rim.
  Corner radius ~24dp; ~3dp inset so the contact shadow/rim read.
  No internal refraction lens: pure XML can only fake it with a hard-edged radial
  oval, which read as a stray blue spot (more obvious on dark glass), so it was
  dropped for a single continuous top sheen with no center stop (no mid-height line).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Contact shadow: deeper dark drop shadow, slight downward offset for a subtle float. Kept close
         to the body inset so it doesn't protrude as an uneven bottom edge. glassShadow #060810 @ ~0.4 -> #66060810 -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="4dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#66060810" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Frosted body: cool blue-gray dark glass, diagonal gradient. start rgba(36,48,66,0.55)->#8C243042, end rgba(22,30,43,0.6)->#99161E2B -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#8C243042"
                android:endColor="#99161E2B"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Top sheen: a gentle 2-stop white->transparent vertical gradient over the FULL body shape.
         Brightest at the very top, fading continuously to transparent at the bottom — no center stop,
         so there's no mid-height boundary line. Nests in the rounded corners; scales with any size. -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#14FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Single hairline rim, cool stroke. (A second inset rim diverged from this one when the launcher
         stretches the drawable to non-square widget sizes, so the double rim is collapsed to one.)
         glassStrokeCool-aligned #3E5A7A @ ~0.30 -> #4D3E5A7A -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#4D3E5A7A" />
            <corners android:radius="24dp" />
        </shape>
    </item>

</layer-list>
