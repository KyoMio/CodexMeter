<?xml version="1.0" encoding="utf-8"?>
<!--
  LIGHT "liquid glass" widget backdrop, pure <layer-list>/<shape> reproduction.
  Auto-swapped against drawable-night by the launcher under -night; DESIGN.md §912.
  Layers bottom->top: contact shadow, frosted body, top sheen, single hairline rim.
  Corner radius ~24dp; ~3dp inset so the contact shadow/rim read.
  No internal refraction lens: pure XML can only fake it with a hard-edged radial
  oval, which read as a stray blue spot on the small widget, so it was dropped in
  favour of a single continuous top sheen with no center stop (no mid-height line).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Contact shadow: cool blue-gray, slight downward offset for a subtle float. Kept close to the
         body inset so it doesn't protrude as an uneven bottom edge. rgba(40,70,110,0.28) -> #47284A6E -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="4dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#47284A6E" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Frosted body: cool-white frosted glass, diagonal gradient. start rgba(244,249,255,0.74)->#BCF4F9FF, end rgba(228,239,252,0.66)->#A8E4EFFC -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#BCF4F9FF"
                android:endColor="#A8E4EFFC"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Top sheen: a gentle 2-stop white->transparent vertical gradient over the FULL body shape.
         Brightest at the very top, fading continuously to transparent at the bottom — no center stop,
         so there's no mid-height boundary line. Nests in the rounded corners; scales with any size. -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#99FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Single hairline rim, cool-blue. (A second inset rim diverged from this one when the launcher
         stretches the drawable to non-square widget sizes, so the double rim is collapsed to one.)
         rgba(150,180,220,0.5) -> #8096B4DC -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#8096B4DC" />
            <corners android:radius="24dp" />
        </shape>
    </item>

</layer-list>
