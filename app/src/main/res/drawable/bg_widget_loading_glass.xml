<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Faint attached contact shadow; keep it close so the loading widget does not look thick. -->
    <item
        android:bottom="2dp"
        android:left="18dp"
        android:right="18dp"
        android:top="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#085C83B0" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Light cool-blue frosted body with one hairline rim. -->
    <item
        android:bottom="3dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:centerColor="#60385652"
                android:endColor="#5C2E405C"
                android:startColor="#70445E7C" />
            <stroke
                android:width="1dp"
                android:color="#28FFFFFF" />
            <corners android:radius="26dp" />
            <padding
                android:bottom="12dp"
                android:left="14dp"
                android:right="14dp"
                android:top="12dp" />
        </shape>
    </item>

    <!-- Narrow top glint attached to the same glass body. -->
    <item
        android:bottom="48dp"
        android:left="4dp"
        android:right="4dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#28FFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</layer-list>
